<form class="ui stacked segment form" action="/dashboard/addcollection" method="POST" enctype="multipart/form-data">


  <div class="two fields">
    <div class="field">
      <label>Collection Name</label>
      <input placeholder="Name" type="text" name="title" autofocus required>
    </div>

    <div class="field">
      <label>Image</label>
      <input placeholder="Image" type="file" name="picture" required>
    </div>
  </div>
  
 <button class="ui blue submit button">Add Collection</button>