<form class="ui stacked segment form" action="/collection/{{id}}/addgame" method="POST" enctype="multipart/form-data">
  
  <div class="four fields">
    <div class="field">
      <label>Game Title</label>
      <input type="text" name="title" autofocus required title = "Please include a valid Title"
	    placeholder="Title">
    </div>

    <div class="field">
      <label>Platform</label>
      <input type="text" name="platform" required title = "Please include a valid Platform"
	    placeholder="Platform"  >
    </div>

    <div class="field">
      <label>Number of Trophies</label>
      <input type="number" name="trophies" required title = "Please include a valid number of trophies"
	    placeholder="Number of Trophies"  >
    </div>

    <div class="field">
      <label>Game Image</label>
      <input placeholder="Image" type="file" name="picture" required>
    </div>
  </div>

  <button class="ui blue submit button">Add Game</button>
</form>