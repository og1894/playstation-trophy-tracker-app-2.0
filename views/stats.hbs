{{> menu id="stats"}}

<section class="ui center aligned middle aligned segment">
  <h2>Trophy Tracker App Statistics</h2>
</section>

<section class="ui center aligned middle aligned segment">

  <h3 class="ui header">
    App Statistics
  </h3>
  <p>
    The trophy tracker app now contains:
  </p>
  {{#with stats}}
  <div class="ui center aligned grid">

    <div class="ui sixteen wide column">

      <div class="ui centered three statistics">
        <div class="ui statistic">
          <div class="value">
            <i class="folder icon"></i>
          </div>
          <div class="label">
            {{displayNumCollections}} collections
          </div>
        </div>

        <div class="ui blue statistic">
          <div class="value">
            <i class="gamepad icon"></i>
          </div>
          <div class="label">
            {{displayNumGames}} games
          </div>
        </div>

        <div class="ui red statistic">
          <div class="value">
            <i class="balance scale icon"></i>
          </div>
          <div class="label">
            Average games per <br> collection: {{displayAverage}}
          </div>
        </div>
      </div>
    </div>

    <div class="ui sixteen wide column">
      <div class="ui centered three statistics">

        <div class="ui yellow statistic">
          <div class="value">
            <i class="star icon"></i>
          </div>
          <div class="label">
            Highest Rated Collections: {{highest}} stars
            <table>
              {{#each displayFav}}
              <tr>
                <td>{{this}}</td>
              </tr>
              {{/each}}
            </table>
          </div>
        </div>

        <div class="ui green statistic">
          <div class="value">
            <i class="dot circle outline icon"></i>
          </div>
          <div class="label">
            Average Rating: {{displayAvgRating}}
          </div>
        </div>
		
      </div>
    </div>
    
  </div>

  {{/with}}

</section>